# Copy to `.env.development.local`, `.env.staging.local`, or `.env.production.local`.
# Never commit real keys. Service role belongs ONLY on the server / Supabase dashboard — never VITE_*.

# --- Supabase (browser-safe: anon key only) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Public site URL used for email verification + password reset redirects (no trailing slash).
# Local: http://localhost:5173
# Staging: https://waka-pos-staging.vercel.app
# Production: https://your-domain.com
VITE_APP_URL=http://localhost:5173

# Optional: shown in PWA manifest install name
# VITE_APP_NAME=Waka POS
# VITE_APP_SHORT_NAME=WakaPOS

# Optional: POST minimal JSON events from reportMonitoringEvent (see src/lib/monitoring.ts)
# VITE_MONITORING_INGEST_URL=
