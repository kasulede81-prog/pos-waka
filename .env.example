# Copy to `.env.development.local`, `.env.staging.local`, or `.env.production.local`.
# Never commit real keys. Service role belongs ONLY on the server / Supabase dashboard — never VITE_*.

# --- Supabase (browser-safe: anon key only) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Public site URL used for email verification + password reset redirects (no trailing slash).
# Local: http://localhost:5173
# Staging: https://waka-pos-staging.vercel.app
# Production: https://your-domain.com
VITE_APP_URL=http://localhost:5173

# Branded Google Sign-In (same Web Client ID as Supabase → Google → Authorized Client IDs)
# VITE_GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
# VITE_ENABLE_GOOGLE_AUTH=false

# Optional: shown in PWA manifest install name
# VITE_APP_NAME=Waka POS
# VITE_APP_SHORT_NAME=WakaPOS

# Optional: POST minimal JSON events from reportMonitoringEvent (see src/lib/monitoring.ts)
# VITE_MONITORING_INGEST_URL=

# --- Sentry crash reporting (optional) ---
# Create projects: waka-pos-dev, waka-pos-staging, waka-pos-production
# VITE_SENTRY_DSN=https://xxx@o000.ingest.sentry.io/000
# VITE_SENTRY_ENVIRONMENT=production
# VITE_APP_VERSION=1.0.4
# VITE_SENTRY_DEBUG=true

# --- Resend (Supabase Edge Functions only — never VITE_*) ---
# Set via: supabase secrets set --env-file supabase/functions/.env
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM="Waka POS <noreply@waka.ug>"
# EMAIL_REPLY_TO=support@waka.ug
# SEND_EMAIL_HOOK_SECRET=v1,whsec_xxxxxxxx
# SEND_WELCOME_ON_SIGNUP=true
