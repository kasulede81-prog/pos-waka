# Vite mode: staging (`npm run build:staging`)
# Copy to `.env.staging.local` (gitignored). Use a separate Supabase project or branch DB if possible.

VITE_SUPABASE_URL=https://YOUR_STAGING_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_staging_anon_key
VITE_APP_URL=https://your-staging-host.vercel.app
# VITE_APP_NAME=Waka POS (Staging)
# VITE_MONITORING_INGEST_URL=
