# Supabase Edge Function secrets (auth-send-email hook).
# Copy to supabase/functions/.env and run:
#   supabase secrets set --env-file supabase/functions/.env --project-ref YOUR_PROJECT_REF
#
# Never commit real keys.

RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM="Waka POS <noreply@waka.ug>"
EMAIL_REPLY_TO=support@waka.ug
SEND_EMAIL_HOOK_SECRET=v1,whsec_your_hook_secret_from_supabase_dashboard
# Optional: set to false to skip the welcome email after signup verification
SEND_WELCOME_ON_SIGNUP=true
