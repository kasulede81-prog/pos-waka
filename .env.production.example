# Vite mode: production (`npm run build` or `npm run build:production`)
# Copy to `.env.production.local` (gitignored). Vercel: set the same keys in Project → Settings → Environment Variables (Production).

VITE_SUPABASE_URL=https://ljaedextsenbkxzzgxcg.supabase.co
VITE_SUPABASE_ANON_KEY=your_production_anon_key

# REQUIRED — auth redirects (must match Supabase Auth Site URL)
VITE_APP_URL=https://pos.waka.ug

# REQUIRED for branded Google Sign-In (Waka logo/name on Google screen, NOT supabase.co)
# Web client ID from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
VITE_GOOGLE_OAUTH_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

VITE_APP_NAME=Waka POS
VITE_APP_SHORT_NAME=WakaPOS
